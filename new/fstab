# Static information about the filesystems.
# See fstab(5) for details.

# <file system> <dir> <type> <options> <dump> <pass>
# /dev/sda2
UUID=###	/	ext4	rw,relatime	0	1

# /dev/sda1
UUID=###	/boot	vfat	rw,relatime,fmask=0077,dmask=0077,codepage=437,iocharset=ascii,shortname=mixed,utf8,errors=remount-ro	0	2

# /dev/sda3
UUID=###	/mnt/storage	ext4	rw,relatime	0	2

/mnt/storage/home				/home			none		bind		0 0
/mnt/storage/www				/var/www		none		bind		0 0
/mnt/storage/bin				/usr/local/bin	none		bind		0 0
/mnt/storage/images		/var/lib/libvirt/images	none		bind		0 0

# /dev/sdb1
UUID=###	/mnt/backup	ext4     rw,noatime,nofail	0 0

# /dev/sda4
UUID=###	none	swap	defaults	0	0

